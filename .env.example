# Project Settings
PROJECT_NAME="Production RAG System"
DEBUG=True

# Infrastructure (ChromaDB + Redis)
CHROMA_HOST="localhost"
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME="production-rag"
REDIS_URL="redis://localhost:6379"

# Google Gemini API
GOOGLE_API_KEY="your-google-api-key-here"
GEMINI_MODEL="gemini-3-flash-preview"

# External Search (Tavily)
TAVILY_API_KEY="your-tavily-api-key-here"

# Observability (Opik)
OPIK_API_KEY="your-opik-api-key-here"
OPIK_HOST="http://localhost:8080"
OPIK_PROJECT_NAME="production-rag"

# Security
ALLOWED_HOSTS="*"
